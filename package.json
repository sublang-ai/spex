{
  "name": "@sublang/spex",
  "version": "0.1.1",
  "description": "The essential spec layer AI agents need to build software reliably",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sublang-ai/spex.git"
  },
  "keywords": [
    "spex",
    "ai-agents",
    "specs",
    "specification",
    "spec-driven-development",
    "scaffold",
    "cli"
  ],
  "bin": {
    "spex": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.d.ts",
    "scaffold/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "test": "node scripts/run-tests.cjs",
    "test:integration": "node scripts/run-tests.cjs \"\\.integration\\.test\\.js$\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  }
}
