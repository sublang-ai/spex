{
  "name": "spex-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Spex: the desktop app for running playbooks, and the @sublang/spex scaffold CLI",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sublang-ai/spex.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
