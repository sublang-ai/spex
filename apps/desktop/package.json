{
  "name": "spex-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Spex \u2014 the desktop app for running playbooks",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sublang-ai/spex.git",
    "directory": "apps/desktop"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node scripts/stage-ui.mjs",
    "start": "npm run build && electron .",
    "test": "node --test dist/*.test.js",
    "package": "npm run build && npm run rebuild:electron && electron-builder --mac --arm64 --dir",
    "rebuild:electron": "node scripts/rebuild-native.mjs electron",
    "rebuild:node": "node scripts/rebuild-native.mjs node"
  },
  "dependencies": {
    "@sublang/spex-core": "*"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.8.0"
  },
  "build": {
    "appId": "ai.sublang.spex",
    "productName": "Spex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*.js",
      "preload.cjs",
      "!dist/**/*.test.js",
      "ui-dist/**"
    ],
    "asarUnpack": [
      "**/node_modules/@anthropic-ai/claude-agent-sdk/**",
      "**/node_modules/@anthropic-ai/claude-agent-sdk-*/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null,
      "category": "public.app-category.developer-tools"
    }
  }
}