{
  "name": "@sublang/spex-core",
  "version": "0.1.0",
  "private": true,
  "description": "Spex core service: headless playbook host behind a typed WebSocket API",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sublang-ai/spex.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": "./dist/index.js",
    "./protocol": "./dist/protocol.js",
    "./testing": "./dist/testing/index.js"
  },
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.d.ts",
    "assets/"
  ],
  "scripts": {
    "build": "tsc",
    "dev:fake": "npm run build && node dist/bin/dev-core.js --fake",
    "test": "node scripts/run-tests.cjs",
    "test:integration": "node scripts/run-tests.cjs \"\\.integration\\.test\\.js$\""
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "@sublang/cligent": "^0.13.0",
    "@sublang/playbook": "^0.9.0",
    "better-sqlite3": "^12.2.0",
    "esbuild": "^0.24.2",
    "ws": "^8.18.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "typescript": "^5.8.0"
  }
}
