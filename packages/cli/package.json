{
  "name": "@sublang/spex",
  "version": "0.3.0",
  "description": "The essential spec layer AI agents need to build software reliably",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sublang-ai/spex.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "spex",
    "ai-agents",
    "specs",
    "specification",
    "spec-driven-development",
    "scaffold",
    "cli"
  ],
  "bin": {
    "spex": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.d.ts",
    "scaffold/"
  ],
  "scripts": {
    "build": "tsc && node scripts/stage-scaffold.mjs",
    "prepublishOnly": "npm run build && npm test",
    "test": "node scripts/stage-scaffold.mjs && node scripts/run-tests.cjs",
    "test:integration": "node scripts/stage-scaffold.mjs && node scripts/run-tests.cjs \"\\.integration\\.test\\.js$\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
}
